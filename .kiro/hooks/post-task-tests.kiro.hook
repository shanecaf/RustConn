{
  "enabled": true,
  "name": "Test After Spec Task",
  "description": "Runs cargo test after each spec task completes to catch regressions early. Uses askAgent to prevent duplicate test runs.",
  "shortName": "post-task-tests",
  "version": "3",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "askAgent",
    "prompt": "A spec task just completed. Run `cargo test --workspace` to verify no regressions. IMPORTANT RULES:\n\n1. Before starting tests, check if another cargo process is running: `pgrep -f 'cargo test'`. If one is already running, SKIP this test run and report: \"Tests already in progress, skipping duplicate run.\"\n\n2. Do NOT pipe through tail or grep — run the command directly so you can see progress.\n\n3. Allow up to 180 seconds — argon2 property tests are slow in debug mode, this is normal.\n\n4. Report only the final summary line (e.g. \"test result: ok. 42 passed; 0 failed\"). If tests fail, report the failing test names.\n\n5. Do NOT re-run tests if they are already running from a previous hook or sub-agent invocation."
  }
}
